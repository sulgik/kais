{
  "tactics": {
    "AML.TA0002": {"name": "정찰", "description": "공격자가 향후 작전에 활용할 AI 시스템 정보를 수집합니다. 피해 조직의 AI 역량·연구 현황 등을 능동·수동으로 파악하는 기법을 포함합니다."},
    "AML.TA0003": {"name": "자원 개발", "description": "공격자가 작전 지원에 활용할 자원(인프라·계정·도구·AI 아티팩트 등)을 구축·획득합니다."},
    "AML.TA0004": {"name": "초기 접근", "description": "공격자가 대상 AI 시스템 또는 관련 인프라에 처음 발판을 마련합니다."},
    "AML.TA0000": {"name": "AI 모델 접근", "description": "공격자가 대상 AI 모델에 대한 다양한 수준의 접근권을 획득합니다. 공격의 출발점이 되는 전술입니다."},
    "AML.TA0005": {"name": "실행", "description": "공격자가 피해자의 시스템 또는 AI 환경에서 악성 코드·명령을 실행합니다."},
    "AML.TA0006": {"name": "지속성 유지", "description": "공격자가 AI 시스템 내 발판을 장기간 유지하기 위한 기법입니다."},
    "AML.TA0012": {"name": "권한 상승", "description": "공격자가 AI 시스템이나 관련 인프라에서 더 높은 권한을 획득합니다."},
    "AML.TA0007": {"name": "방어 회피", "description": "공격자가 AI 시스템의 보안 탐지 및 방어 메커니즘을 우회합니다."},
    "AML.TA0013": {"name": "자격증명 탈취", "description": "공격자가 AI 시스템 접근에 사용되는 계정 정보·API 키·토큰 등을 탈취합니다."},
    "AML.TA0008": {"name": "탐색", "description": "공격자가 AI 시스템의 내부 구조, 모델 아키텍처, 데이터 구성 등을 파악합니다."},
    "AML.TA0015": {"name": "수평 이동", "description": "공격자가 AI 시스템과 연결된 다른 시스템·컴포넌트로 이동합니다."},
    "AML.TA0009": {"name": "수집", "description": "공격자가 공격 목적에 필요한 AI 모델·데이터·결과물 등을 수집합니다."},
    "AML.TA0001": {"name": "AI 공격 준비", "description": "공격자가 대상 AI 시스템에 맞춰 공격 도구·페이로드를 준비하고 스테이징합니다."},
    "AML.TA0014": {"name": "명령 및 제어", "description": "공격자가 침해된 AI 시스템을 원격에서 제어하기 위한 통신 채널을 구성합니다."},
    "AML.TA0010": {"name": "데이터 유출", "description": "공격자가 AI 모델·학습 데이터·추론 결과 등을 외부로 반출합니다."},
    "AML.TA0011": {"name": "영향", "description": "공격자가 AI 시스템의 무결성·가용성·신뢰성을 훼손하거나 오용합니다."}
  },
